<%- include('layouts/header') %>

<div class="max-w-xl mx-auto px-4 py-8"
     data-timer="<%= QUIZ_TIMER %>"
     data-save-url="<%= saveUrl %>"
     data-monument-id="<%= monument.id %>">

  <!-- Header -->
  <div class="text-center mb-8 pb-6 border-b border-base-300">
    <h2 class="font-oswald text-3xl text-primary"><%= monument.name %></h2>
    <p class="text-base-content/55 text-sm mt-1">
      5 questions · <%= QUIZ_TIMER %> secondes par question · 1 point par bonne réponse
    </p>
  </div>

  <!-- Quiz section -->
  <div id="quiz-section">
    <!-- Progress -->
    <div class="flex items-center gap-3 mb-6">
      <div class="flex-1 h-1.5 bg-gray-200 rounded-full overflow-hidden">
        <div class="h-full bg-primary rounded-full transition-all duration-500" id="progress-fill" style="width:0%"></div>
      </div>
      <span class="text-xs font-semibold text-base-content/50 whitespace-nowrap" id="progress-label">Question 1 / 5</span>
    </div>

    <!-- Timer -->
    <div class="text-center mb-5">
      <div class="timer-circle" id="timer-circle">
        <span id="timer-count"><%= QUIZ_TIMER %></span>
      </div>
    </div>

    <!-- Question card -->
    <div class="card bg-base-200 border border-base-300 shadow-xl">
      <div class="card-body p-6">
        <p class="text-base font-semibold text-center mb-5 leading-relaxed text-base-content/90" id="question-text"></p>
        <ul class="flex flex-col gap-2" id="answers-list"></ul>
      </div>
    </div>
  </div>

  <!-- Résultat -->
  <div id="result-section" style="display:none">
    <div class="text-center">
      <h2 class="font-oswald text-4xl mb-2">Quiz terminé !</h2>

      <!-- Score circle -->
      <div class="mx-auto my-6 w-32 h-32 rounded-full flex items-center justify-center
                  bg-primary/10 border-4 border-primary/25
                  font-oswald text-3xl font-bold text-primary"
           id="score-value">0 / 5</div>

      <p class="text-base-content/65 text-sm mb-7" id="result-message"></p>

      <!-- Share -->
      <div class="card bg-base-200 border border-base-300 mb-5">
        <div class="card-body p-5">
          <p class="font-semibold text-sm mb-4">📣 Partage ta découverte !</p>
          <div class="flex gap-2 justify-center flex-wrap">
            <a id="share-whatsapp" href="#" target="_blank"
               class="btn btn-sm gap-2 text-white border-0" style="background:#25D366">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.855L.057 23.882l6.188-1.443A11.944 11.944 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.886 0-3.65-.502-5.178-1.378l-.371-.22-3.674.857.895-3.558-.242-.38A9.944 9.944 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
              WhatsApp
            </a>
            <a id="share-facebook" href="#" target="_blank"
               class="btn btn-sm gap-2 text-white border-0" style="background:#1877F2">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
            <a id="share-twitter" href="#" target="_blank"
               class="btn btn-sm gap-2 text-white border-0 bg-black hover:bg-neutral-800">
              <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              X / Twitter
            </a>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <a href="/leaderboard" class="btn btn-primary btn-lg">Voir le classement</a>
        <a href="/" class="btn btn-ghost">Retour à l'accueil</a>
      </div>
    </div>
  </div>

</div>

<script>
window.QUIZ_DATA     = <%- jsQuestions %>;
window.MONUMENT_NAME = '<%= monument.name.replace(/'/g, "\\'") %>';
window.SHARE_URL     = '<%= APP_URL %>';
document.body.dataset.timer      = '<%= QUIZ_TIMER %>';
document.body.dataset.saveUrl    = '<%= saveUrl %>';
document.body.dataset.monumentId = '<%= monument.id %>';
</script>
<script src="/js/quiz.js"></script>

<%- include('layouts/footer') %>
