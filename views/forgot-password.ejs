<%- include('layouts/header') %>

<div class="flex justify-center items-start pt-14 px-4 pb-12">
<div class="card bg-base-200 border border-base-300 shadow-2xl w-full max-w-sm">
  <div class="card-body p-7">
    <h1 class="font-oswald text-3xl text-center mb-2">Mot de passe oublié</h1>
    <p class="text-center text-sm text-base-content/55 mb-5">Entrez votre adresse e-mail et nous vous enverrons un lien de réinitialisation.</p>
    <% if (error && error.length) { %>
    <div class="alert alert-error text-sm rounded-lg mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-4 w-4" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <span><%= error[0] %></span>
    </div>
    <% } %>
    <% if (success && success.length) { %>
    <div class="alert alert-success text-sm rounded-lg mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-4 w-4" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <span><%= success[0] %></span>
    </div>
    <% } %>
    <form method="post" action="/auth/forgot-password" class="flex flex-col gap-4">
      <label class="form-control">
        <div class="label pb-1"><span class="label-text text-xs font-semibold uppercase tracking-widest text-base-content/60">E-mail</span></div>
        <input type="email" name="email" required autocomplete="email"
               class="input input-bordered bg-base-300 border-base-300 focus:border-primary focus:outline-none w-full">
      </label>
      <button type="submit" class="btn btn-primary w-full mt-1">Envoyer le lien</button>
    </form>
    <p class="text-center text-xs text-base-content/50 mt-4">
      <a href="/auth/login" class="link link-primary font-semibold">Retour à la connexion</a>
    </p>
  </div>
</div>
</div>

<%- include('layouts/footer') %>
