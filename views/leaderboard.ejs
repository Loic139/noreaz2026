<%- include('layouts/header') %>

<div class="max-w-3xl mx-auto px-4 py-10">

  <div class="flex items-center justify-between mb-6">
    <h1 class="font-oswald text-4xl">Classement général</h1>
    <span class="text-base-content/65 text-xs" id="last-update">Mis à jour toutes les 10 secondes</span>
  </div>

  <% if (user && myRank) { %>
  <div class="alert bg-primary/10 border border-primary/20 mb-6 rounded-xl">
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-primary shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <span>Ton classement : <strong class="text-primary">#<%= myRank %></strong> avec <strong><%= myScore %> point(s)</strong></span>
  </div>
  <% } %>

  <div id="leaderboard-container">
    <% if (!ranking.length) { %>
    <div class="alert bg-base-200 border border-base-300 rounded-xl">
      Personne n'a encore joué. Sois le premier !
    </div>
    <% } else { %>
    <div class="overflow-x-auto rounded-xl border border-base-300">
      <table class="table table-zebra bg-base-200">
        <thead>
          <tr class="bg-base-300 text-base-content/55 text-xs uppercase tracking-widest border-b border-base-300">
            <th class="w-14">#</th>
            <th>Joueur</th>
            <th>Points</th>
            <th>Monuments joués</th>
          </tr>
        </thead>
        <tbody>
        <% ranking.forEach((row, i) => { %>
        <% const isMe = user && row.user_id === user.id; %>
        <tr class="<%= i === 0 ? 'font-semibold' : '' %> <%= isMe ? 'bg-primary/10' : '' %>">
          <td class="text-xl leading-none py-3">
            <% if(i===0){%>🥇<%}else if(i===1){%>🥈<%}else if(i===2){%>🥉<%}else{%><span class="text-base-content/50 text-sm font-bold"><%= i+1 %></span><%}%>
          </td>
          <td><%= row.first_name %> <%= row.last_name %><% if (isMe) { %> <span class="badge badge-primary badge-xs ml-1">toi</span><% } %></td>
          <td>
            <span class="text-primary font-bold"><%= row.total %></span>
            <span class="text-base-content/65 text-xs"> / <%= nbMonuments * QUIZ_QUESTIONS %></span>
          </td>
          <td class="text-base-content/60 text-sm"><%= row.monuments_joues %> / <%= nbMonuments %></td>
        </tr>
        <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <% if (!user) { %>
  <div class="text-center mt-12">
    <p class="text-base-content/55 text-sm mb-4">Inscris-toi pour figurer dans le classement !</p>
    <a href="/auth/register" class="btn btn-primary btn-lg px-10">S'inscrire gratuitement</a>
  </div>
  <% } %>

</div>

<script>
setInterval(function() {
    fetch('/api/leaderboard')
        .then(r => r.json())
        .then(function(data) {
            const medals = ['🥇','🥈','🥉'];
            let html = '';
            if (!data.ranking.length) {
                html = '<div class="alert bg-base-200 border border-base-300 rounded-xl">Personne n\'a encore joué. Sois le premier !</div>';
            } else {
                html = '<div class="overflow-x-auto rounded-xl border border-base-300"><table class="table table-zebra bg-base-200"><thead><tr class="bg-base-300 text-base-content/55 text-xs uppercase tracking-widest border-b border-base-300"><th class="w-14">#</th><th>Joueur</th><th>Points</th><th>Monuments joués</th></tr></thead><tbody>';
                data.ranking.forEach((row, i) => {
                    const rank = i < 3 ? `<span class="text-xl">${medals[i]}</span>` : `<span class="text-base-content/50 text-sm font-bold">${i+1}</span>`;
                    html += `<tr class="${i===0?'font-semibold':''}"><td class="py-3">${rank}</td><td>${row.first_name} ${row.last_name}</td><td><span class="text-primary font-bold">${row.total}</span></td><td class="text-base-content/60 text-sm">${row.nb} / ${data.nbMonuments}</td></tr>`;
                });
                html += '</tbody></table></div>';
            }
            document.getElementById('leaderboard-container').innerHTML = html;
            document.getElementById('last-update').textContent = 'Mis à jour à ' + new Date().toLocaleTimeString('fr-CH');
        }).catch(() => {});
}, 10000);
</script>

<%- include('layouts/footer') %>
