<!DOCTYPE html>
<html lang="fr" data-theme="lofi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4/dist/full.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen flex flex-col bg-base-100">

<div class="navbar bg-base-200 border-b border-base-300 px-4 sticky top-0 z-50">
  <div class="navbar-start">
    <span class="font-oswald text-primary text-lg tracking-wide">ADMIN</span>
    <span class="text-base-content/65 text-xs ml-2 hidden sm:inline">Noréaz 2026</span>
  </div>
  <div class="navbar-end flex gap-1">
    <a href="/admin" class="btn btn-ghost btn-xs">Dashboard</a>
    <a href="/admin/monuments" class="btn btn-ghost btn-xs">Monuments</a>
    <a href="/admin/users" class="btn btn-ghost btn-xs">Joueurs</a>
    <a href="/admin/print-cards" class="btn btn-ghost btn-xs" target="_blank">🖨️ Cartes</a>
    <form method="post" action="/admin/logout" class="inline">
      <button type="submit" class="btn btn-ghost btn-xs text-error/60">Quitter</button>
    </form>
  </div>
</div>

<div class="max-w-5xl mx-auto px-4 py-8 w-full flex-1">

  <% if (msg) { %>
  <div class="alert alert-<%= msgType === 'danger' ? 'error' : 'success' %> mb-6 rounded-xl text-sm">
    <span><%= msg %></span>
  </div>
  <% } %>

  <!-- Ajouter un monument -->
  <div class="flex items-center justify-between mb-4">
    <h2 class="font-oswald text-xl">Ajouter un monument</h2>
  </div>
  <div class="card bg-base-200 border border-base-300 mb-8">
    <div class="card-body p-5">
      <form method="post" action="/admin/monuments/add" enctype="multipart/form-data">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
          <label class="form-control">
            <div class="label pb-1"><span class="label-text text-xs uppercase tracking-widest text-base-content/60">Nom *</span></div>
            <input type="text" name="name" required class="input input-bordered input-sm bg-base-300 border-base-300 focus:border-primary focus:outline-none">
          </label>
          <label class="form-control">
            <div class="label pb-1"><span class="label-text text-xs uppercase tracking-widest text-base-content/60">Pays</span></div>
            <input type="text" name="country" class="input input-bordered input-sm bg-base-300 border-base-300 focus:border-primary focus:outline-none">
          </label>
        </div>
        <label class="form-control mb-4">
          <div class="label pb-1"><span class="label-text text-xs uppercase tracking-widest text-base-content/60">Description</span></div>
          <input type="text" name="desc" class="input input-bordered input-sm bg-base-300 border-base-300 focus:border-primary focus:outline-none">
        </label>
        <label class="form-control mb-4">
          <div class="label pb-1"><span class="label-text text-xs uppercase tracking-widest text-base-content/60">Indice (homepage)</span></div>
          <input type="text" name="hint" placeholder="Ex: Je me trouve près de la fontaine" class="input input-bordered input-sm bg-base-300 border-base-300 focus:border-primary focus:outline-none">
        </label>
        <div class="flex items-center gap-4">
          <input type="file" name="image" accept="image/jpeg,image/png,image/webp" class="file-input file-input-sm file-input-bordered bg-base-300 border-base-300 flex-1">
          <button type="submit" class="btn btn-primary btn-sm px-6">Ajouter</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Liste -->
  <div class="flex items-center justify-between mb-4">
    <h2 class="font-oswald text-xl">Monuments (<%= monuments.length %>)</h2>
  </div>
  <% if (!monuments.length) { %>
  <div class="alert bg-base-200 border border-base-300 text-sm">Aucun monument. Ajoutez-en un ci-dessus.</div>
  <% } else { %>
  <div class="overflow-x-auto rounded-xl border border-base-300">
    <table class="table table-zebra bg-base-200">
      <thead>
        <tr class="bg-base-300 text-base-content/55 text-xs uppercase tracking-widest">
          <th>Photo</th><th>Nom</th><th>Pays</th><th>Questions</th><th>Statut</th><th>Actions</th>
        </tr>
      </thead>
      <tbody>
      <% monuments.forEach(m => { %>
      <tr>
        <td class="w-16">
          <% if (m.image) { %>
          <img src="/img/monuments/<%= m.image %>" alt="" class="w-12 h-12 object-cover rounded-lg">
          <% } else { %>
          <div class="w-12 h-12 bg-base-300 rounded-lg flex items-center justify-center text-2xl">🏛️</div>
          <% } %>
        </td>
        <td class="font-semibold text-sm"><%= m.name %></td>
        <td class="text-base-content/60 text-sm"><%= m.country || '—' %></td>
        <td>
          <a href="/admin/questions?monument_id=<%= m.id %>" class="btn btn-ghost btn-xs text-primary">
            <%= m.nb_questions %> q.
          </a>
        </td>
        <td>
          <span class="badge badge-xs <%= m.active ? 'badge-success' : 'badge-error' %>">
            <%= m.active ? 'Actif' : 'Inactif' %>
          </span>
        </td>
        <td>
          <div class="flex gap-1 flex-wrap">
            <!-- Upload photo -->
            <form method="post" action="/admin/monuments/<%= m.id %>/upload" enctype="multipart/form-data"
                  id="uf-<%= m.id %>">
              <label for="img-<%= m.id %>" class="btn btn-ghost btn-xs cursor-pointer">📷</label>
              <input type="file" id="img-<%= m.id %>" name="image" accept="image/jpeg,image/png,image/webp"
                     class="hidden" onchange="document.getElementById('uf-<%= m.id %>').submit()">
            </form>
            <form method="post" action="/admin/monuments/<%= m.id %>/toggle" class="inline">
              <button type="submit" class="btn btn-ghost btn-xs">
                <%= m.active ? 'Désact.' : 'Act.' %>
              </button>
            </form>
            <form method="post" action="/admin/monuments/<%= m.id %>/delete" class="inline"
                  onsubmit="return confirm('Supprimer ce monument ?')">
              <button type="submit" class="btn btn-ghost btn-xs text-error/60">Suppr.</button>
            </form>
          </div>
        </td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

</div>

<footer class="footer footer-center p-4 bg-base-200 text-base-content/20 border-t border-base-300 text-xs">
  <span>Admin — Noréaz 2026</span>
</footer>
</body>
</html>
