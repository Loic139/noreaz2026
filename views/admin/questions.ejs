<!DOCTYPE html>
<html lang="fr" data-theme="lofi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4/dist/full.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="min-h-screen flex flex-col bg-base-100">

<div class="navbar bg-base-200 border-b border-base-300 px-4 sticky top-0 z-50">
  <div class="navbar-start">
    <span class="font-oswald text-primary text-lg tracking-wide">ADMIN</span>
    <span class="text-base-content/65 text-xs ml-2 hidden sm:inline">Noréaz 2026</span>
  </div>
  <div class="navbar-end flex gap-1">
    <a href="/admin" class="btn btn-ghost btn-xs">Dashboard</a>
    <a href="/admin/monuments" class="btn btn-ghost btn-xs">Monuments</a>
    <a href="/admin/users" class="btn btn-ghost btn-xs">Joueurs</a>
    <a href="/admin/logout" class="btn btn-ghost btn-xs text-error/60">Quitter</a>
  </div>
</div>

<div class="max-w-4xl mx-auto px-4 py-8 w-full flex-1">

  <div class="flex items-start justify-between mb-6">
    <div>
      <h2 class="font-oswald text-2xl">Questions — <%= monument.name %></h2>
      <p class="text-base-content/55 text-sm mt-1"><%= questions.length %> / <%= QUIZ_QUESTIONS %> questions</p>
    </div>
    <a href="/admin/monuments" class="btn btn-ghost btn-sm">← Retour</a>
  </div>

  <% if (msg) { %>
  <div class="alert alert-success mb-5 rounded-xl text-sm"><span><%= msg %></span></div>
  <% } %>

  <!-- Formulaire ajouter / modifier -->
  <% if (questions.length < QUIZ_QUESTIONS || editQ) { %>
  <div class="card bg-base-200 border border-base-300 mb-8">
    <div class="card-body p-5">
      <h3 class="font-oswald text-lg mb-4"><%= editQ ? 'Modifier la question' : 'Ajouter une question' %></h3>
      <form method="post" action="<%= editQ ? '/admin/questions/edit' : '/admin/questions/add' %>" class="flex flex-col gap-4">
        <input type="hidden" name="monument_id" value="<%= monument.id %>">
        <% if (editQ) { %><input type="hidden" name="question_id" value="<%= editQ.id %>"><% } %>

        <label class="form-control">
          <div class="label pb-1"><span class="label-text text-xs uppercase tracking-widest text-base-content/60">Question *</span></div>
          <input type="text" name="question" required value="<%= editQ ? editQ.question_text : '' %>"
                 class="input input-bordered bg-base-300 border-base-300 focus:border-primary focus:outline-none">
        </label>

        <label class="form-control">
          <div class="label pb-1"><span class="label-text text-xs uppercase tracking-widest text-success/70">✓ Bonne réponse *</span></div>
          <input type="text" name="correct" required value="<%= editQ ? editQ.answer_correct : '' %>"
                 class="input input-bordered bg-base-300 border-success/20 focus:border-success focus:outline-none">
        </label>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <label class="form-control">
            <div class="label pb-1"><span class="label-text text-xs uppercase tracking-widest text-base-content/50">✗ Mauvaise 1 *</span></div>
            <input type="text" name="wrong1" required value="<%= editQ ? editQ.answer_wrong1 : '' %>"
                   class="input input-bordered input-sm bg-base-300 border-base-300 focus:border-error focus:outline-none">
          </label>
          <label class="form-control">
            <div class="label pb-1"><span class="label-text text-xs uppercase tracking-widest text-base-content/50">✗ Mauvaise 2 *</span></div>
            <input type="text" name="wrong2" required value="<%= editQ ? editQ.answer_wrong2 : '' %>"
                   class="input input-bordered input-sm bg-base-300 border-base-300 focus:border-error focus:outline-none">
          </label>
          <label class="form-control">
            <div class="label pb-1"><span class="label-text text-xs uppercase tracking-widest text-base-content/50">✗ Mauvaise 3 *</span></div>
            <input type="text" name="wrong3" required value="<%= editQ ? editQ.answer_wrong3 : '' %>"
                   class="input input-bordered input-sm bg-base-300 border-base-300 focus:border-error focus:outline-none">
          </label>
        </div>

        <div class="flex gap-2 mt-1">
          <button type="submit" class="btn btn-primary btn-sm px-6"><%= editQ ? 'Enregistrer' : 'Ajouter' %></button>
          <% if (editQ) { %>
          <a href="/admin/questions?monument_id=<%= monument.id %>" class="btn btn-ghost btn-sm">Annuler</a>
          <% } %>
        </div>
      </form>
    </div>
  </div>
  <% } else { %>
  <div class="alert bg-base-200 border border-base-300 text-sm mb-8 rounded-xl">
    Ce monument a déjà <%= QUIZ_QUESTIONS %> questions. Supprimez-en une pour en ajouter.
  </div>
  <% } %>

  <!-- Liste des questions -->
  <h3 class="font-oswald text-lg mb-3">Questions existantes</h3>
  <% if (!questions.length) { %>
  <div class="alert bg-base-200 border border-base-300 text-sm">Aucune question pour ce monument.</div>
  <% } else { %>
  <div class="flex flex-col gap-3">
  <% questions.forEach((q, i) => { %>
  <div class="card bg-base-200 border border-base-300 <%= (editQ && editQ.id === q.id) ? 'border-primary/30' : '' %>">
    <div class="card-body p-4 flex-row items-start justify-between gap-4">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-2">
          <span class="badge badge-ghost badge-sm font-mono"><%= i+1 %></span>
          <p class="font-semibold text-sm truncate"><%= q.question_text %></p>
        </div>
        <p class="text-success text-xs font-semibold">✓ <%= q.answer_correct %></p>
        <p class="text-base-content/50 text-xs mt-1"><%= q.answer_wrong1 %> · <%= q.answer_wrong2 %> · <%= q.answer_wrong3 %></p>
      </div>
      <div class="flex gap-1 flex-shrink-0">
        <a href="/admin/questions?monument_id=<%= monument.id %>&edit=<%= q.id %>"
           class="btn btn-ghost btn-xs text-primary">Modifier</a>
        <a href="/admin/questions/delete?id=<%= q.id %>&monument_id=<%= monument.id %>"
           onclick="return confirm('Supprimer cette question ?')"
           class="btn btn-ghost btn-xs text-error/60">Suppr.</a>
      </div>
    </div>
  </div>
  <% }) %>
  </div>
  <% } %>

</div>

<footer class="footer footer-center p-4 bg-base-200 text-base-content/20 border-t border-base-300 text-xs">
  <span>Admin — Noréaz 2026</span>
</footer>
</body>
</html>
