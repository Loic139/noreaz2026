<!DOCTYPE html>
<html lang="fr" data-theme="lofi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof pageTitle !== 'undefined' ? pageTitle : 'Noréaz 2026 — Les Monuments' %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/daisyui@4/dist/full.min.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/style.css">
</head>
<script>
(function() {
    <% if (user && user.persistent_token) { %>
    // Utilisateur connecté : sauvegarder le token
    localStorage.setItem('noreaz_pt', '<%= user.persistent_token %>');
    <% } else if (!user) { %>
    // Pas de session : tenter un auto-login via localStorage
    var pt = localStorage.getItem('noreaz_pt');
    if (pt) {
        fetch('/auth/auto-login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token: pt })
        })
        .then(function(r) { return r.json(); })
        .then(function(d) { if (d.ok) location.reload(); else localStorage.removeItem('noreaz_pt'); })
        .catch(function() {});
    }
    <% } %>
})();
</script>
<body class="min-h-screen flex flex-col">

<div class="navbar bg-base-200 border-b border-base-300 sticky top-0 z-50 px-4">
  <div class="navbar-start">
    <div class="dropdown">
      <div tabindex="0" role="button" class="btn btn-ghost btn-sm lg:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16"/>
        </svg>
      </div>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow-2xl bg-base-100 rounded-box w-48 border border-base-300">
        <li><a href="/">Accueil</a></li>
        <li><a href="/leaderboard">Classement</a></li>
        <% if (user) { %>
        <li class="menu-title opacity-40 text-xs"><%= user.first_name %></li>
        <li><a href="/auth/profile">Mon profil</a></li>
        <li>
          <form method="post" action="/auth/logout" class="p-0">
            <button type="submit" class="text-error w-full text-left">Déconnexion</button>
          </form>
        </li>
        <% } else { %>
        <li><a href="/auth/login">Se connecter</a></li>
        <li><a href="/auth/register">S'inscrire</a></li>
        <% } %>
      </ul>
    </div>
    <a href="/" class="flex flex-col leading-none ml-1 hover:opacity-80 transition-opacity">
      <span class="font-oswald text-xl font-bold text-primary tracking-wider">NORÉAZ</span>
      <span class="text-[.58rem] text-base-content/65 font-semibold tracking-[.2em] uppercase">Les Monuments 2026</span>
    </a>
  </div>
  <div class="navbar-end hidden lg:flex gap-1">
    <a href="/" class="btn btn-ghost btn-sm font-medium">Accueil</a>
    <a href="/leaderboard" class="btn btn-ghost btn-sm font-medium">Classement</a>
    <div class="divider divider-horizontal mx-1"></div>
    <% if (user) { %>
    <a href="/auth/profile" class="btn btn-ghost btn-sm font-medium"><%= user.first_name %></a>
    <form method="post" action="/auth/logout" class="inline">
      <button type="submit" class="btn btn-ghost btn-sm text-error/60 hover:text-error">Déconnexion</button>
    </form>
    <% } else { %>
    <a href="/auth/login" class="btn btn-ghost btn-sm font-medium">Se connecter</a>
    <a href="/auth/register" class="btn btn-primary btn-sm ml-1">S'inscrire</a>
    <% } %>
  </div>
</div>

<main class="flex-1">
<% if (user && !user.email_verified) { %>
<div class="bg-warning/15 border-b border-warning/30 text-warning-content px-4 py-2 text-xs text-center">
    Votre adresse e-mail n'est pas encore confirmée.
    <form method="post" action="/auth/resend-verification" class="inline">
        <button type="submit" class="underline font-semibold hover:opacity-75">Renvoyer l'e-mail</button>
    </form>
</div>
<% } %>
