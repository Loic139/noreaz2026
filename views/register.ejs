<%- include('layouts/header') %>

<div class="flex justify-center items-start pt-14 px-4 pb-12">
<div class="card bg-base-200 border border-base-300 shadow-2xl w-full max-w-sm">
  <div class="card-body p-7">
    <h1 class="font-oswald text-3xl text-center mb-5">S'inscrire</h1>
    <% if (error && error.length) { %>
    <div class="alert alert-error text-sm rounded-lg mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-4 w-4" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <span><%= error[0] %></span>
    </div>
    <% } %>
    <form method="post" action="/auth/register?redirect=<%= encodeURIComponent(redirect) %>" class="flex flex-col gap-4">
      <div class="grid grid-cols-2 gap-3">
        <label class="form-control">
          <div class="label pb-1"><span class="label-text text-xs font-semibold uppercase tracking-widest text-base-content/60">Prénom</span></div>
          <input type="text" name="first_name" required autocomplete="given-name"
                 class="input input-bordered input-sm bg-base-300 border-base-300 focus:border-primary focus:outline-none w-full">
        </label>
        <label class="form-control">
          <div class="label pb-1"><span class="label-text text-xs font-semibold uppercase tracking-widest text-base-content/60">Nom</span></div>
          <input type="text" name="last_name" required autocomplete="family-name"
                 class="input input-bordered input-sm bg-base-300 border-base-300 focus:border-primary focus:outline-none w-full">
        </label>
      </div>
      <label class="form-control">
        <div class="label pb-1"><span class="label-text text-xs font-semibold uppercase tracking-widest text-base-content/60">E-mail</span></div>
        <input type="email" name="email" required autocomplete="email"
               class="input input-bordered bg-base-300 border-base-300 focus:border-primary focus:outline-none w-full">
      </label>
      <label class="form-control">
        <div class="label pb-1">
          <span class="label-text text-xs font-semibold uppercase tracking-widest text-base-content/60">Mot de passe</span>
          <span class="label-text-alt text-base-content/65">6 car. min.</span>
        </div>
        <input type="password" name="password" required autocomplete="new-password"
               class="input input-bordered bg-base-300 border-base-300 focus:border-primary focus:outline-none w-full">
      </label>
      <label class="form-control">
        <div class="label pb-1"><span class="label-text text-xs font-semibold uppercase tracking-widest text-base-content/60">Confirmer</span></div>
        <input type="password" name="confirm" required autocomplete="new-password"
               class="input input-bordered bg-base-300 border-base-300 focus:border-primary focus:outline-none w-full">
      </label>
      <button type="submit" class="btn btn-primary w-full mt-1">Créer mon compte</button>
    </form>
    <p class="text-center text-xs text-base-content/50 mt-4">
      Déjà un compte ?
      <a href="/auth/login?redirect=<%= encodeURIComponent(redirect) %>" class="link link-primary font-semibold">Se connecter</a>
    </p>
  </div>
</div>
</div>

<%- include('layouts/footer') %>
