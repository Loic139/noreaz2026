<%- include('layouts/header') %>

<!-- Hero -->
<div class="relative overflow-hidden bg-base-200 border-b border-base-300">
  <div class="absolute inset-0 bg-gradient-to-b from-gray-50 to-white opacity-80"></div>
  <div class="relative text-center py-16 px-4">
    <div class="badge badge-outline badge-primary font-semibold tracking-widest uppercase text-xs mb-5">
      24 – 28 juin 2026
    </div>
    <h1 class="font-oswald text-5xl md:text-6xl font-bold mb-3">
      <span class="text-primary">Noréaz</span> les Monuments
    </h1>
    <p class="text-base-content/65 text-base max-w-sm mx-auto">
      Scanne les QR codes cachés dans le village, découvre les monuments et réponds aux quiz !
    </p>
  </div>
</div>

<div class="max-w-5xl mx-auto px-4 py-10">

  <!-- Comment jouer -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-10">
    <div class="card bg-base-200 border border-base-300 text-center shadow-sm">
      <div class="card-body py-6 px-5">
        <div class="text-4xl mb-2">🔍</div>
        <h3 class="font-oswald text-lg mb-1">1. Trouve</h3>
        <p class="text-base-content/60 text-sm">Pars à la découverte des monuments miniatures cachés dans le village de Noréaz.</p>
      </div>
    </div>
    <div class="card bg-base-200 border border-base-300 text-center shadow-sm">
      <div class="card-body py-6 px-5">
        <div class="text-4xl mb-2">📱</div>
        <h3 class="font-oswald text-lg mb-1">2. Scanne</h3>
        <p class="text-base-content/60 text-sm">Scanne le QR code sur le monument avec ton téléphone.</p>
      </div>
    </div>
    <div class="card bg-base-200 border border-base-300 text-center shadow-sm">
      <div class="card-body py-6 px-5">
        <div class="text-4xl mb-2">🏆</div>
        <h3 class="font-oswald text-lg mb-1">3. Réponds</h3>
        <p class="text-base-content/60 text-sm">Réponds aux 5 questions en moins de 10 secondes chacune et marque des points !</p>
      </div>
    </div>
  </div>

  <% if (user && foundIds.length > 0) { %>
  <div class="alert bg-primary/10 border border-primary/20 text-base-content mb-8 rounded-xl">
    <svg xmlns="http://www.w3.org/2000/svg" class="stroke-primary shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <span>Tu as trouvé <strong class="text-primary"><%= foundIds.length %></strong> monument(s) sur <strong><%= monuments.length %></strong> !</span>
  </div>
  <% } %>

  <!-- Monuments -->
  <div class="flex items-center justify-between mb-5">
    <h2 class="font-oswald text-2xl font-bold">Monuments à trouver</h2>
    <div class="badge badge-ghost text-base-content/60"><%= monuments.length %> monuments</div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-12">
  <% monuments.forEach(m => { %>
  <% const found = user && foundIds.includes(m.id); %>

    <% if (found) { %>
    <a href="/monument?token=<%= encodeURIComponent(m.qr_token) %>"
       class="card bg-base-200 border border-success/15 shadow-md hover:-translate-y-1 transition-transform duration-200 cursor-pointer">
      <% if (m.image) { %>
      <figure class="aspect-video overflow-hidden">
        <img src="/img/monuments/<%= m.image %>" alt="<%= m.name %>" class="w-full h-full object-cover">
      </figure>
      <% } else { %>
      <div class="aspect-video flex items-center justify-center bg-base-300 text-5xl">🏛️</div>
      <% } %>
      <div class="card-body p-4 gap-1">
        <div class="badge badge-success badge-sm font-semibold">✓ Trouvé</div>
        <h3 class="card-title font-oswald text-base mt-1"><%= m.name %></h3>
        <% if (m.country) { %><p class="text-primary text-xs font-semibold">📍 <%= m.country %></p><% } %>
        <p class="text-xs text-base-content/40 mt-1">Cliquer pour rejouer →</p>
      </div>
    </a>

    <% } else { %>
    <div class="card bg-base-200 border border-base-300 shadow-md hover:-translate-y-1 transition-transform duration-200">
      <!-- Image floutée ou placeholder ❓ -->
      <% if (m.image) { %>
      <figure class="aspect-video overflow-hidden">
        <img src="/img/monuments/<%= m.image %>" alt="Monument caché"
             class="w-full h-full object-cover blur-sm brightness-50 scale-110 select-none pointer-events-none">
      </figure>
      <% } else { %>
      <div class="aspect-video flex items-center justify-center bg-base-300 text-5xl select-none">❓</div>
      <% } %>
      <div class="card-body p-4 gap-1">
        <h3 class="card-title font-oswald text-base text-base-content/60">Monument caché</h3>
        <% if (m.hint) { %>
        <button class="btn btn-xs btn-outline border-base-300 text-base-content/60 hover:border-primary hover:text-primary w-fit mt-1"
                onclick="toggleHint(this, <%= m.id %>)">💡 Indice</button>
        <p id="hint-<%= m.id %>" class="hidden mt-2 text-xs text-base-content/50 italic border-l-2 border-primary/30 pl-2 leading-relaxed">
          <%= m.hint %>
        </p>
        <% } %>
      </div>
    </div>
    <% } %>

  <% }) %>
  </div>

  <!-- Top classement -->
  <% if (top5.length > 0) { %>
  <div class="flex items-center justify-between mb-5">
    <h2 class="font-oswald text-2xl font-bold">Top classement</h2>
    <a href="/leaderboard" class="btn btn-ghost btn-sm text-base-content/60">Voir tout →</a>
  </div>
  <div class="overflow-x-auto rounded-xl border border-base-300">
    <table class="table table-zebra bg-base-200">
      <thead>
        <tr class="bg-base-300 text-base-content/55 text-xs uppercase tracking-widest border-b border-base-300">
          <th class="w-14">#</th>
          <th>Joueur</th>
          <th>Points</th>
          <th>Monuments</th>
        </tr>
      </thead>
      <tbody>
      <% top5.forEach((row, i) => { %>
      <tr>
        <td class="text-xl leading-none py-3">
          <% if(i===0){%>🥇<%}else if(i===1){%>🥈<%}else if(i===2){%>🥉<%}else{%><span class="text-base-content/50 text-sm font-bold"><%= i+1 %></span><%}%>
        </td>
        <td class="font-semibold"><%= row.first_name %> <%= row.last_name %></td>
        <td><span class="text-primary font-bold"><%= row.total %></span></td>
        <td class="text-base-content/60 text-sm"><%= row.monuments_joues %> / <%= monuments.length %></td>
      </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
  <% } %>

  <% if (!user) { %>
  <div class="text-center mt-14">
    <p class="text-base-content/55 mb-4 text-sm">Inscris-toi pour figurer dans le classement !</p>
    <a href="/auth/register" class="btn btn-primary btn-lg px-10">S'inscrire gratuitement</a>
  </div>
  <% } %>

  <!-- Commentaires -->
  <% const _comments = locals.comments || []; %>
  <div id="comments" class="mt-14">
    <div class="flex items-center justify-between mb-5">
      <h2 class="font-oswald text-2xl font-bold">Messages de la communauté</h2>
      <div class="badge badge-ghost text-base-content/60"><%= _comments.length %> message(s)</div>
    </div>

    <% if (user) { %>
    <div class="card bg-base-200 border border-base-300 mb-6">
      <div class="card-body p-5">
        <form action="/comment" method="POST" class="flex flex-col gap-3">
          <textarea name="content" rows="2" maxlength="500"
            placeholder="Partagez votre expérience, un conseil, un message..."
            class="textarea textarea-bordered bg-base-100 resize-none text-sm w-full focus:border-primary focus:outline-none"
            required></textarea>
          <div class="flex justify-between items-center">
            <span class="text-xs text-base-content/40">Max 500 caractères</span>
            <button type="submit" class="btn btn-primary btn-sm px-6">Publier</button>
          </div>
        </form>
      </div>
    </div>
    <% } else { %>
    <div class="alert bg-base-200 border border-base-300 text-sm mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" class="stroke-primary shrink-0 h-5 w-5" fill="none" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
      <span><a href="/auth/login" class="link-primary font-semibold">Connecte-toi</a> pour laisser un message.</span>
    </div>
    <% } %>

    <% if (_comments.length === 0) { %>
    <div class="text-center py-10 text-base-content/40 text-sm">
      Aucun message pour l'instant. Sois le premier à écrire !
    </div>
    <% } else { %>
    <div class="flex flex-col gap-3">
    <% _comments.forEach(c => { %>
      <div class="card bg-base-200 border border-base-300">
        <div class="card-body p-4 gap-1">
          <div class="flex items-center justify-between gap-2">
            <span class="font-semibold text-sm"><%= c.first_name %> <%= c.last_name %></span>
            <span class="text-xs text-base-content/40"><%= new Date(c.created_at).toLocaleDateString('fr-CH', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
          </div>
          <p class="text-sm text-base-content/75 leading-relaxed"><%= c.content %></p>
        </div>
      </div>
    <% }) %>
    </div>
    <% } %>
  </div>

</div>
<%- include('layouts/footer') %>
